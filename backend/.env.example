# Flask Configuration
FLASK_APP=run.py
FLASK_CONFIG=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=your-secret-key-here

# Database Configuration
DATABASE_URL=sqlite:///./data/urban_navigation.db
REDIS_URL=redis://localhost:6379/0

# Machine Learning Configuration
MODEL_PATH=./data/models
DATA_PATH=./data
LSTM_SEQUENCE_LENGTH=24
LSTM_HIDDEN_UNITS=50
LSTM_DROPOUT_RATE=0.2
LSTM_EPOCHS=100
LSTM_BATCH_SIZE=32

# API Configuration
TRAFFIC_API_KEY=your-traffic-api-key
WEATHER_API_KEY=your-weather-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Cache Configuration
CACHE_DEFAULT_TIMEOUT=300
CACHE_TYPE=redis

# Rate Limiting
RATELIMIT_DEFAULT=100 per hour

# CORS Configuration
CORS_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Traffic and Parking Configuration
TRAFFIC_UPDATE_INTERVAL=300
PREDICTION_HORIZON_HOURS=24
PARKING_UPDATE_INTERVAL=600
MAX_PARKING_DISTANCE=2000
